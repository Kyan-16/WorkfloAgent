# ============================================================
# WorkfloAgent 环境变量配置模板
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
# ============================================================

# ── LLM 配置（必填）──
# 支持 DashScope（阿里通义千问）或 OpenAI 兼容接口（DeepSeek/GLM/Ollama）
LLM_PROVIDER=openai
LLM_MODEL=deepseek-chat
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1

# ── 数据库 ──
DATABASE_URL=sqlite:///data/ticket_agent.db

# ── 模型配置加密密钥 ──
# 不设置则自动生成，删除 data/.model_config_key 后需重新配置
# MODEL_CONFIG_KEY=

# ── JWT 密钥（生产环境请务必设置）──
# 不设置则每次重启生成随机密钥，现有 token 会失效
# JWT_SECRET=

# ── 功能开关 ──
QDRANT_ENABLED=false
MCP_ENABLED=false
PROMETHEUS_ENABLED=false
AGENT_TRACE_ENABLED=true
USE_LANGGRAPH=false

# ── 可选：独立模型配置 ──
# CLASSIFIER_LLM_MODEL=gpt-4o-mini
# EXECUTOR_LLM_MODEL=deepseek-chat

# ── 可选：Qdrant 向量检索 ──
# QDRANT_ENABLED=true
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# EMBEDDING_API_KEY=

# ── 可选：IM 集成 ──
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# WECOM_CORP_ID=
# WECOM_AGENT_ID=
# WECOM_AGENT_SECRET=
# DINGTALK_APP_KEY=
# DINGTALK_APP_SECRET=

# ── 可选：邮件通知（SMTP）──
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com
